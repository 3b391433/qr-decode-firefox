{
  "manifest_version": 2,
  "name": "二维码解码 · QR Decode (cli.im)",
  "version": "1.0.1",
  "description": "右键任意图片即可解码其中的二维码，使用草料二维码 (cli.im) 的解码接口。Right-click any image to decode its QR code via cli.im.",
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": [
    "contextMenus",
    "notifications",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "qr-decode-cliim@local.addon",
      "strict_min_version": "91.0",
      "data_collection_permissions": {
        "required": ["websiteContent"]
      }
    }
  }
}
